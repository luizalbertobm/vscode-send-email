{
  "name": "bee-send-email",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "1.1.1",
  "publisher": "beecoders",
  "author": {
    "name": "Luiz Alberto B. Mesquita",
    "email": "luizalbertobm@gmail.com",
    "url": "https://github.com/luizalbertobm"
  },
  "license": "MIT",
  "icon": "images/icon.png",
  "homepage": "https://www.beecoders.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/luizalbertobm/vscode-send-email.git"
  },
  "bugs": {
    "url": "https://github.com/luizalbertobm/vscode-send-email/issues"
  },
  "galleryBanner": {
    "color": "#6B1C8F",
    "theme": "dark"
  },
  "keywords": [
    "email",
    "gmail",
    "smtp",
    "send email",
    "mail",
    "compose",
    "productivity"
  ],
  "categories": [
    "Other"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [],
  "l10n": "./l10n",
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sendEmail",
          "title": "%activitybar.title%",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "sendEmail": [
        {
          "id": "sendEmail.sidebarForm",
          "name": "%view.name%",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "sendEmail.openForm",
        "title": "%command.sendEmail.title%",
        "category": "%command.sendEmail.category%"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "sendEmail.smtpHost": {
          "type": "string",
          "default": "smtp.gmail.com",
          "description": "%config.smtpHost.description%"
        },
        "sendEmail.smtpPort": {
          "type": "number",
          "default": 465,
          "description": "%config.smtpPort.description%"
        },
        "sendEmail.smtpUser": {
          "type": "string",
          "default": "",
          "description": "%config.smtpUser.description%"
        },
        "sendEmail.smtpPassword": {
          "type": "string",
          "default": "",
          "secret": true,
          "description": "%config.smtpPassword.description%"
        },
        "sendEmail.fromAddress": {
          "type": "string",
          "default": "",
          "description": "%config.fromAddress.description%"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.js",
    "watch": "node esbuild.config.js --watch",
    "l10n:export": "npx @vscode/l10n-dev export --outDir ./l10n ./src",
    "package": "npm run build && vsce package",
    "publish": "npm run build && vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.0",
    "@types/vscode": "^1.80.0",
    "@vscode/l10n-dev": "^0.0.35",
    "@vscode/vsce": "^2.32.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "nodemailer": "^6.9.0"
  }
}
